# llauncher Environment Configuration

# Path to llama-server binary (default: ~/.local/bin/llama-server)
# LLAMA_SERVER_PATH=/path/to/llama-server

# Path to launch scripts directory (default: ~/.local/bin)
# SCRIPTS_PATH=~/.local/bin

# Default port to use for new models (default: 8080)
# DEFAULT_PORT=8080

# Blacklisted ports (comma-separated, default: 8080)
# BLACKLISTED_PORTS=8080,8081,8082

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
